---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { albums } from "../../data/albums";

export async function getStaticPaths() {
  return albums.map((album) => ({
    params: { id: album.id },
  }));
}

const album = albums.find((a) => a.id === Astro.params.id);
const photos = album?.photos || [];
---

<BaseLayout title={album ? `${album.event} - 照片墙` : `照片墙`} description={album?.description}>
  <div class="mb-10 animate-fade-in-up">
    <div class="mb-4">
      <h1 class="text-3xl md:text-4xl font-bold flex items-center gap-3">
        <Icon name="lucide:camera" class="text-primary" />
        <span>{album ? `${album.icon || ''} ${album.event}` : '照片墙'}</span>
      </h1>
    </div>

    {album?.description && (
      <p class="text-base-content/70 text-lg mb-6">
        {album.description}
      </p>
    )}
    {!album && (
      <p class="text-base-content/70 text-lg mb-6">
        照片集
      </p>
    )}

    {photos.length === 0 ? (
      <div class="text-center py-24 text-base-content/20">
        <Icon name="lucide:camera" class="w-16 h-16 mx-auto mb-3 opacity-20" />
        <p class="text-lg">暂无照片</p>
      </div>
    ) : (
      <div class="columns-1 sm:columns-2 lg:columns-3 gap-6 space-y-6">
        {photos.map((photo) => (
          <div class="break-inside-avoid bg-base-100 rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-base-200 group">
            <div class="overflow-hidden rounded-t-3xl">
              <img
                src={photo.src}
                alt={photo.title || ''}
                class="w-full h-auto rounded-t-3xl transform group-hover:scale-105 transition-transform duration-500 ease-out"
                loading="lazy"
              />
            </div>
            {photo.title && (
              <div class="p-5">
                <h3 class="text-xl font-bold mb-2">{photo.title}</h3>
                {photo.description && <p class="text-base-content/70 text-sm">{photo.description}</p>}
              </div>
            )}
          </div>
        ))}
      </div>
    )}
  </div>

  <div class="divider my-6 animate-fade-in-up" style="animation-delay: 0.1s;">
    <Icon name="lucide:heart" class="w-12 h-12 text-primary/50" />
  </div>
</BaseLayout>
