---
import BaseLayout from "@/layouts/BaseLayout.astro";
import MusicPlayer from "@/components/widgets/MusicPlayer.astro";
import { musicList, playlistCounts, playlistSongs } from "@/data/music";
import { MUSIC_CONFIG } from "@/config";

const basePlaylists = MUSIC_CONFIG?.playlists || [];
const playlists = [
  { id: "all", name: "全部音乐" },
  ...basePlaylists.map(pl => ({ id: pl.id, name: pl.name }))
];

const counts = { ...playlistCounts, "all": musicList.length };
const songs = { ...playlistSongs, "all": musicList };
---

<BaseLayout title="音乐" showSidebar={true} showTOC={false} isIndexed={false}>
  <div class="py-8 px-4">
    <MusicPlayer
      list={musicList}
      playlists={playlists}
      playlistCounts={counts}
      playlistSongs={songs}
    />
  </div>
</BaseLayout>
